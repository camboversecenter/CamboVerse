{
  "name": "camboverse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mobile-first, web-first viewer for the Open Khmer Heritage Archive. A Digital Public Good stewarded by the CamboVerse Center at NUM.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc -b",
    "cf-typegen": "wrangler types",
    "gen:model": "node scripts/generate-model.mjs",
    "gen:angkor": "node scripts/generate-angkor.mjs",
    "gen:bayon": "node scripts/generate-bayon.mjs",
    "gen:taprohm": "node scripts/generate-taprohm.mjs",
    "gen:preahvihear": "node scripts/generate-preahvihear.mjs",
    "gen:royalpalace": "node scripts/generate-royalpalace.mjs",
    "gen:banteaysrei": "node scripts/generate-banteaysrei.mjs",
    "gen:watphnom": "node scripts/generate-watphnom.mjs",
    "gen:kaom": "node scripts/generate-kaom.mjs",
    "gen:changkran": "node scripts/generate-changkran.mjs",
    "gen:house": "node scripts/generate-house.mjs",
    "gen:cake": "node scripts/generate-cake.mjs",
    "gen:glyphs": "node scripts/generate-glyph-paths.mjs",
    "gen:roneat": "node scripts/generate-roneat.mjs",
    "gen:skor": "node scripts/generate-skor.mjs",
    "gen:map": "node scripts/generate-map-outline.mjs",
    "gen:provinces": "node scripts/generate-provinces.mjs",
    "gen:districts": "node scripts/generate-districts.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/xr": "^6.6.30",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^5.20260708.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "opentype.js": "^2.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
